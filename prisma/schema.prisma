generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  READER
  LIBRARIAN
}

enum CopyStatus {
  AVAILABLE
  BORROWED
  DAMAGED
  LOST
}

enum CopyCondition {
  NEW
  GOOD
  WORN
  DAMAGED
}

enum LoanStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum ReservationStatus {
  PENDING
  AWAITING_PICKUP
  FULFILLED
  CANCELLED
  EXPIRED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(READER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loans        Loan[]
  reservations Reservation[]

  @@map("users")
}

model Book {
  id            String   @id @default(cuid())
  title         String
  author        String
  isbn          String   @unique
  coverUrl      String?
  synopsis      String?
  genre         String?
  publishedYear Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  copies       Copy[]
  reservations Reservation[]

  @@index([title])
  @@index([author])
  @@map("books")
}

model Copy {
  id        String        @id @default(cuid())
  code      String        @unique
  bookId    String
  status    CopyStatus    @default(AVAILABLE)
  condition CopyCondition @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  book  Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  loans Loan[]

  @@index([bookId])
  @@map("copies")
}

model Loan {
  id         String     @id @default(cuid())
  userId     String
  copyId     String
  loanDate   DateTime   @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     LoanStatus @default(ACTIVE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id])
  copy Copy @relation(fields: [copyId], references: [id])

  @@index([userId])
  @@index([copyId])
  @@index([status])
  @@map("loans")
}

model Reservation {
  id        String            @id @default(cuid())
  userId    String
  bookId    String
  status    ReservationStatus @default(PENDING)
  position  Int
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
  @@index([bookId, status])
  @@map("reservations")
}
